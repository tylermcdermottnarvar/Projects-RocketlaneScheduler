# ─────────────────────────────────────────────
# Narvar Meeting Scheduler — Environment Variables
# Copy this to .env.local for local dev
# Add each in Vercel dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────

# Rocketlane API key
# Get from: Rocketlane → Settings → Developer → API Keys
ROCKETLANE_API_KEY=your_rocketlane_api_key_here

# SMTP email sending
# For Gmail: use an App Password (not your regular password)
# Get one at: myaccount.google.com/apppasswords
# (Requires 2FA to be enabled on your Google account)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tyler.mcdermott@narvar.com
SMTP_PASS=your_gmail_app_password_here

# Pilot mode — all emails route here during testing
PILOT_EMAIL=tyler.mcdermott@narvar.com

# Your Vercel deployment URL (set after first deploy)
APP_URL=http://localhost:3000

# Webhook security secret (any random string)
WEBHOOK_SECRET=narvar-pilot-2026
