# ─────────────────────────────────────────────
# Narvar Meeting Scheduler — Environment Variables
# Copy this to .env.local for local dev
# Add each variable in Vercel dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────

# Rocketlane
ROCKETLANE_API_KEY=your_rocketlane_api_key_here

# Google OAuth2 (Service Account or OAuth credentials)
# Go to: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
# Email address of the Google Workspace account used to send emails + query calendars
GOOGLE_SERVICE_EMAIL=your_service_account@narvar.com

# Pilot mode — all outbound emails route here instead of real recipients
PILOT_EMAIL=tyler.mcdermott@narvar.com

# App URL — set this to your Vercel deployment URL once deployed
# e.g. https://narvar-scheduler.vercel.app
APP_URL=http://localhost:3000

# Webhook security — generate any random string, add it to Rocketlane webhook config
WEBHOOK_SECRET=generate_a_random_secret_here
